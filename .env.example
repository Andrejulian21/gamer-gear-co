# Database (PostgreSQL - Neon free tier recommended)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Wompi (Colombian payment gateway)
# Get sandbox keys at https://docs.wompi.co/docs/en/test-account
WOMPI_ENV="sandbox"
NEXT_PUBLIC_WOMPI_PUBLIC_KEY="pub_test_xxxxxxxxxxxxxxxx"
WOMPI_PRIVATE_KEY="prv_test_xxxxxxxxxxxxxxxx"
WOMPI_EVENTS_SECRET="your-events-secret-here"

# Resend (transactional emails)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"

# Vercel Blob (image storage for product photos)
BLOB_READ_WRITE_TOKEN="vercel_blob_xxxxxxxxxxxxxxxx"
